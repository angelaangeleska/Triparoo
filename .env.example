DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/family_trip_planner
SECRET_KEY=change-me-to-a-long-random-secret-key
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback
RECOMMENDATION_PROVIDER=mock
# serpapi = Google Flights real-time (recommended) | amadeus = live prices | global = estimates | auto = best available
FLIGHT_PROVIDER=serpapi
ACCOMMODATION_PROVIDER=serpapi
ACCOMMODATION_PROVIDER=mock

# Free test API keys: https://developers.amadeus.com/my-apps
AMADEUS_CLIENT_ID=your_amadeus_api_key
AMADEUS_CLIENT_SECRET=your_amadeus_api_secret
AMADEUS_BASE_URL=https://test.api.amadeus.com
# Set true only for demo without Amadeus keys (uses estimates, not real airlines)
AMADEUS_FALLBACK_TO_ESTIMATES=false
# SerpAPI — get your key at https://serpapi.com/manage-api-key
SERPAPI_API_KEY=your_serpapi_key_here

DEBUG=true
